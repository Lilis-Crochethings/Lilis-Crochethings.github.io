---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutCard from '../components/main/AboutCard.astro';
import CreationsCard from '../components/main/CreationsCard.astro';
import GalleryCard from '../components/main/GalleryCard.astro';
import PatternsCard from '../components/main/PatternsCard.astro';
import { getCollection } from 'astro:content';

const allCreations = (await getCollection('creations')).sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);

// TODO: revisit this card's design (currently just a static grid of covers,
// same as PatternsCard) — capped at 4 for now so it doesn't grow unbounded
// as more creations get added.
const creationCovers = allCreations.slice(0, 4).map((creation) => ({
  image: creation.data.images[0],
  title: creation.data.title,
}));

// Capped at 2 images per creation for the marquee — showing every image of
// every creation ballooned to 100+ <img> tags (doubled again for the
// seamless-loop duplicate), which only gets worse as the collection grows.
const MARQUEE_IMAGES_PER_CREATION = 2;
const galleryImages = allCreations.flatMap((creation) =>
  creation.data.images.slice(0, MARQUEE_IMAGES_PER_CREATION).map((image) => ({ image, title: creation.data.title }))
);
---

<BaseLayout
  description="Lili's Crochethings — handmade crochet bags, amigurumi, and blankets, plus free interactive crochet patterns to make your own."
>

<div class="home-stack">
<AboutCard
  name="Lili"
  bio={[
    "Hi, I'm Lili and I found my love for crochet in the summer of 2023. I then started to share my crochet pieces on Instagram and have been expanding my socials since.",
    "You can take a look around on my website where you can find my creations and my patterns. They're specially designed to be interactive on the web.",
    "If you like my stuff, you can give me a follow on my socials.",
    "However, currently the site is still work in progress...",
  ]}
  image="/images/Lilis-Crochethings-thumb.webp"
/>

<CreationsCard creations={creationCovers} />

<GalleryCard creations={galleryImages} />

<PatternsCard
  patterns={[
    { image: "/images/creations/Bunny.webp", title: "Bunny" },
    { image: "/images/creations/Sleepy-Bunny-1.webp", title: "Sleepy Bunny" },
    { image: "/images/creations/Goose-1.webp", title: "Goose" }
  ]}
/>
</div>

</BaseLayout>

<style>
.home-stack {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}
</style>